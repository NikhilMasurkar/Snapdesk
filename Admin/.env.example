# Same Supabase project as UserMenuList / BusinessDashboard
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."

# Supabase → Project Settings → API keys → service_role (SECRET — server only)
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# Admin access is controlled by the admin_users TABLE (see phase3.sql manual
# steps), not an env var. Public menu app, used for "view live menu" links:
NEXT_PUBLIC_MENU_BASE_URL="https://snapdesk-tan.vercel.app"
